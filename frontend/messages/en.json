    "pain": {
      "title": "Where does an FDE's time really go?",
      "sub": "Even the best FDEs get stuck in documentation. flowFD gives that time back.",
      "item1": {
        "title": "Lost to administrative work",
        "desc": "Even top FDEs spend 40–60% of their time on meeting notes, documentation, and status reports. Actual engineering gets what's left."
      },
      "item2": {
        "unit": "days",
        "title": "Meeting to PRD turnaround",
        "desc": "Understanding context, structuring findings, writing docs, and sharing with the team takes days. Context fades while you wait."
      },
      "item3": {
        "unit": "",
        "title": "Customer projects to juggle",
        "desc": "More projects mean more context collisions. Finding what was decided for which customer takes longer than it should."
      }
    },
    "how": {
      "title": "Record the meeting. The rest is automatic.",
      "sub": "Input your notes in any format. flowFD structures, connects, and builds prototype from them.",
      "step1": {
        "title": "Capture meetings in any format",
        "desc": "Brainstorm notes, transcripts, rough sketches — paste anything into the markdown editor. Add as many entries per day as you need.",
        "tag": "Markdown editor · File upload"
      },
      "step2": {
        "title": "CPS is generated and kept up to date",
        "desc": "A Context-Problem-Solution document is created in the background the moment you save. Every new meeting triggers a review — only what needs changing gets updated.",
        "tag": "Auto-analysis · Version history · Decision Log"
      },
      "step3": {
        "title": "CPS flows into PRD, design, and prototype",
        "desc": "PRD is drafted from CPS. Architecture and dev planning follow. No matter which LLM generates the prototype, the linter enforces consistent naming and style.",
        "tag": "LangChain · Multi-model · Linter"
      },
      "step4": {
        "title": "Sync everything to GitHub",
        "desc": "Docs and prototype land in one GitHub repo. Review the diff, write a commit message, and push — on your terms.",
        "tag": "Human-in-the-loop · Diff preview"
      }
    },
    "why": {
      "title": "Built specifically for FDEs",
      "sub": "This isn't a generic project tool. It's designed around the FDE work cycle from end to end.",
      "item1": {
        "title": "Preserve first, judge later",
        "desc": "Raw meeting notes are never modified. Something that seems irrelevant today might be the key insight tomorrow."
      },
      "item2": {
        "title": "Same output from any LLM",
        "desc": "Gemini, Claude, GPT — the linter enforces naming rules regardless. Switch models anytime without losing code consistency."
      },
      "item3": {
        "title": "Complete project isolation",
        "desc": "Handle multiple customers simultaneously without context bleed. Share knowledge within your team and search across all past projects."
      },
      "item4": {
        "title": "Human-in-the-loop",
        "desc": "Automation isn't everything. GitHub sync, manual CPS edits, model selection — every critical action is reviewed and triggered by a human."
      }
    },
